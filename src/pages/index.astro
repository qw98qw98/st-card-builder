              }, 'ai'));
            });
            renderEntriesList(); debouncedUpdateAndSave();
            if (hacker) hacker.setDetail('✅ 批次 ' + batchIndex + ' 完成，已 ' + worldbookEntries.length + ' 条');
            await sleep(300);
          } catch(bErr) {
            if (hacker) hacker.setDetail('⚠️ 批次 ' + batchIndex + ': ' + bErr.message);
            await sleep(500);
          }
          remaining -= batchSize;
        }

        // 完成
        if (hacker) {
          hacker.stop(); hacker.setPhase('🎉 生成完毕！'); hacker.setProgress(totalSteps, totalSteps);
          var doneMsg = '角色「' + charName.value.trim() + '」+ ' + worldbookEntries.length + ' 条骨架已就绪。';
          if (searchEnabled && cachedSearchResults) doneMsg += ' (参考了 ' + cachedSearchResults.length + ' 条搜索结果)';
          doneMsg += ' 请用「✨ AI重写」逐条展开。';
          hacker.setDetail(doneMsg);
          setTimeout(function() { if (hacker) hacker.hide(); }, 5000);
