    presetInput.addEventListener('change', function(e) {
      var file = e.target.files[0]; if (!file) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        try {
          var data = JSON.parse(ev.target.result);
          parsedPresetList = [];
          if (data.prompts) {
            var ao = (data.prompt_order && data.prompt_order.length > 0)
              ? data.prompt_order[data.prompt_order.length - 1].order : [];
            var ei = ao.filter(function(i) { return i.enabled; }).map(function(i) { return i.identifier; });
            data.prompts.forEach(function(p) {
              if (p.content && !p.marker) {
                parsedPresetList.push({
                  id:                 p.identifier,
                  name:               p.name || '规则',
                  content:            p.content,
                  role:               p.role || 'system',
                  injection_position: p.injection_position || 0,
                  injection_depth:    p.injection_depth || 4,
                  enabled:            ao.length > 0 ? ei.indexOf(p.identifier) >= 0 : true
                });
              }
            });
          }
          renderPresetList();
          saveAIConfig();  // ★ 导入后立即保存
        } catch(err) {
          presetStatus.innerHTML = "❌ 解析失败: " + err.message;
          presetStatus.style.color = '#ef4444';
          presetListContainer.style.display = 'none';
        }
      };
      reader.readAsText(file);
    });

    function readFileAsArrayBuffer(file) {
      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload = function(ev) { resolve(ev.target.result); };
        reader.onerror = function() { reject(new Error('无法读取文件')); };
        reader.readAsArrayBuffer(file);
      });
    }

    function readFileAsDataURL(file) {
      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload = function(ev) { resolve(String(ev.target.result || '')); };
        reader.onerror = function() { reject(new Error('无法读取文件')); };
        reader.readAsDataURL(file);
      });
    }

    function extractPNGCharaChunk(bytes) {
      var i = 8;
      while (i < bytes.length - 12) {
        var length =
          (bytes[i]   << 24 | bytes[i+1] << 16 |
           bytes[i+2] <<  8 | bytes[i+3]) >>> 0;
        var type = String.fromCharCode(
          bytes[i+4], bytes[i+5], bytes[i+6], bytes[i+7]
        );
        if (type === 'tEXt') {
          var dataStart = i + 8;
          var dataEnd   = i + 8 + length;
          var data      = bytes.slice(dataStart, dataEnd);
          var nullPos = data.indexOf(0);
          if (nullPos < 0) {
            i += 12 + length;
            continue;
          }

          var keyword = '';
          for (var k = 0; k < nullPos; k++) {
            keyword += String.fromCharCode(data[k]);
          }

          if (keyword === 'chara' || keyword === 'ccv3') {
            var value = '';
            for (var v = nullPos + 1; v < data.length; v++) {
              value += String.fromCharCode(data[v]);
            }
            return value;
          }
        }
        if (type === 'IEND') break;
        i += 12 + length;
      }
      return null;
    }

    function importCardOrWorldbookText(text, fallbackName) {
      var payload = parseWorldbookImportJSON(text);
      if (isCharacterCardPayload(payload)) {
        applyJSONFromEditor(payload);
        var card = normalizeImportedCharacterCard(payload);
        showImportStatus('已导入角色卡「' + (card && card.charName ? card.charName : fallbackName || '未命名') + '」', 'ok');
        return;
      }
      applyImportedWorldbook(payload, fallbackName);
    }

    function importPngAsset(file, fallbackName) {
      showImportStatus('⏳ 解析 PNG...', 'info');
      Promise.all([readFileAsArrayBuffer(file), readFileAsDataURL(file)]).then(function(results) {
        try {
          var bytes = new Uint8Array(results[0]);
          var avatarBase64 = results[1];
          var charaB64 = extractPNGCharaChunk(bytes);
          if (!charaB64) {
            window.__setImportedAvatar__(avatarBase64);
            showImportStatus('✅ 已更新头像「' + (fallbackName || file.name) + '」', 'ok');
            return;
          }

          var jsonStr = decodeURIComponent(escape(atob(charaB64)));
          var payload = JSON.parse(jsonStr);
          if (!isCharacterCardPayload(payload)) {
            throw new Error('PNG 中的角色数据不是有效角色卡');
          }

          applyJSONFromEditor(payload);
          window.__setImportedAvatar__(avatarBase64);
          var card = normalizeImportedCharacterCard(payload);
          showImportStatus(
            '✅ 已导入角色卡「' + (card && card.charName ? card.charName : fallbackName || file.name) + '」并更新头像',
            'ok'
          );
        } catch (err) {
          showImportStatus('❌ PNG 解析失败：' + err.message, 'error');
        }
      }).catch(function(err) {
        showImportStatus('❌ PNG 解析失败：' + err.message, 'error');
      });
    }

    function handleImportFile(file) {
      if (!file) return;
      var ext = (file.name.split('.').pop() || '').toLowerCase();
      var fallbackName = file.name.replace(/\.[^.]+$/, '') || file.name;
      if (ext === 'png') {
        importPngAsset(file, fallbackName);
        return;
      }
      if (ext === 'json') {
        showImportStatus('⏳ 解析 JSON...', 'info');
        file.text().then(function(text) {
          try {
            importCardOrWorldbookText(String(text || ''), fallbackName);
          } catch (err) {
            showImportStatus('❌ 导入失败：' + err.message, 'error');
          }
        }).catch(function(err) {
          showImportStatus('❌ 导入失败：' + err.message, 'error');
        });
        return;
      }
      showImportStatus('❌ 不支持的文件格式，请选择 .json 或 .png', 'error');
    }

    if (importAssetStatus) {
      showImportStatus('等待导入', 'info');
    }

    if (btnImportAssetFile && importAssetInput) {
      btnImportAssetFile.addEventListener('click', function() {
        importAssetInput.value = '';
        importAssetInput.click();
      });
    }

    if (importAssetInput) {
      importAssetInput.addEventListener('change', function(e) {
        var file = e.target.files && e.target.files[0];
        handleImportFile(file);
      });
    }

    if (btnImportAssetText && importAssetText) {
      btnImportAssetText.addEventListener('click', function() {
        try {
          importCardOrWorldbookText(importAssetText.value || '', '粘贴导入');
        } catch (err) {
          showImportStatus('❌ 导入失败：' + err.message, 'error');
        }
      });
    }

    function getCardRootPayload(json) {
      if (!json || typeof json !== 'object') return null;
      if (json.data && typeof json.data === 'object') return json.data;
      return json;
    }

    function normalizeImportedCharacterCard(json) {
      if (!json || typeof json !== 'object') return null;

      var root = getCardRootPayload(json);
      if (!root) return null;

      var hasCardFields = !!(
        json.spec === 'chara_card_v3' ||
        json.spec_version === '3.0' ||
        root.first_mes !== undefined ||
        root.creator_notes !== undefined ||
        root.mes_example !== undefined ||
        root.alternate_greetings !== undefined ||
        root.nickname !== undefined ||
        root.gender !== undefined ||
        root.statusBlockConfig !== undefined ||
        root.personality !== undefined ||
        root.scenario !== undefined ||
        root.creator !== undefined ||
        root.character_version !== undefined ||
        root.character_book !== undefined
      );
      if (!hasCardFields) return null;

      function coerceImportedPosition(entry) {
        if (!entry || typeof entry !== 'object') return 4;
        if (entry.extensions && entry.extensions.position !== undefined) return safeInt(entry.extensions.position, 4);
        if (entry.position !== undefined) {
          if (entry.position === 'before_char') return 0;
          if (entry.position === 'after_char') return 4;
          return safeInt(entry.position, 4);
        }
        return 4;
      }

      function normalizeAvatarBase64(value) {
        var str = String(value || '').trim();
        if (!str || str.toLowerCase() === 'none') return '';
        if (/^data:image\/[a-z0-9.+-]+;base64,/i.test(str)) return str;
        return '';
      }

      var name = String(root.name || json.name || '').trim();
      var desc = String(root.description || '').trim();
      var personality = String(root.personality || json.personality || '').trim();
      var scenario = String(root.scenario || json.scenario || '').trim();
      var first = String(root.first_mes || '').trim();
      var mesExample = String(root.mes_example || json.mes_example || '').trim();
      var notes = String(root.creator_notes || root.creatorcomment || '').trim();
      var wb = String((root.extensions && root.extensions.world) || root.character_book && root.character_book.name || json.wbName || '').trim();
      var altGreetings = Array.isArray(root.alternate_greetings) ? root.alternate_greetings.slice() : [];
      var tags = Array.isArray(root.tags) ? root.tags.slice() : (Array.isArray(json.tags) ? json.tags.slice() : []);
      var creator = String(root.creator || json.creator || '').trim();
      var characterVersion = String(root.character_version || json.character_version || '').trim();
      var nickname = String(root.nickname || json.nickname || '').trim();
      var gender = String(root.gender || json.gender || '').trim();
      var statusBlockConfig = root.statusBlockConfig && typeof root.statusBlockConfig === 'object'
        ? root.statusBlockConfig
        : (json.statusBlockConfig && typeof json.statusBlockConfig === 'object'
          ? json.statusBlockConfig
          : { description: '', properties: {}, required: [] });
      var regexScripts = [];
      var tavernHelperScripts = [];
      var avatarBase64 = normalizeAvatarBase64(json.avatar || root.avatar || '');

      var characterBook = root.character_book || json.character_book || null;
      var entries = [];
      if (characterBook && Array.isArray(characterBook.entries)) {
        entries = characterBook.entries.slice();
        if (!wb && characterBook.name) wb = String(characterBook.name).trim();
      } else if (characterBook && characterBook.entries && typeof characterBook.entries === 'object') {
        entries = Object.keys(characterBook.entries).map(function(key) { return characterBook.entries[key]; });
      }

      return {
        charName: name,
        wbName: wb,
        charDesc: desc,
        personality: personality,
        scenario: scenario,
        firstMes: first,
        mesExample: mesExample,
        creatorNotes: notes,
        tags: tags,
        creator: creator,
        characterVersion: characterVersion,
        nickname: nickname,
        gender: gender,
        statusBlockConfig: statusBlockConfig,
        worldbookEntries: entries.map(function(e) {
          return normalizeWorldbookEntry({
            comment: e && (e.comment || e.title || e.name) || '',
            content: e && e.content || '',
            keys: Array.isArray(e && e.keys) ? e.keys.slice() : [],
            secondaryKeys: Array.isArray(e && e.secondary_keys) ? e.secondary_keys.slice() : [],
            strategy: e && e.constant ? 'constant' : (e && e.vectorized ? 'vectorized' : (e && e.extensions && e.extensions.vectorized ? 'vectorized' : 'selective')),
            position: coerceImportedPosition(e),
            depth: (e && e.extensions && e.extensions.depth !== undefined) ? e.extensions.depth : 4,
            role: (e && e.extensions && e.extensions.role !== undefined) ? e.extensions.role : 0,
            order: e && e.insertion_order !== undefined ? e.insertion_order : (e && e.order !== undefined ? e.order : 100),
            prob: (e && e.extensions && e.extensions.probability !== undefined) ? e.extensions.probability : (e && e.priority !== undefined ? e.priority : 100),
            enabled: e && e.enabled !== undefined ? !!e.enabled : true,
            useRegex: !!(e && (e.use_regex || e.useRegex)),
            caseSensitive: !!(e && (e.case_sensitive || e.caseSensitive)),
            selectiveLogic: (e && e.extensions && e.extensions.selectiveLogic !== undefined) ? e.extensions.selectiveLogic : 0,
            group: (e && e.extensions && e.extensions.group) || '',
            groupWeight: (e && e.extensions && e.extensions.group_weight !== undefined) ? e.extensions.group_weight : 100,
            useProbability: (e && e.extensions && e.extensions.useProbability !== undefined) ? !!e.extensions.useProbability : true,
            excludeRecursion: !!(e && e.extensions && e.extensions.exclude_recursion),
            preventRecursion: !!(e && e.extensions && e.extensions.prevent_recursion),
            delayUntilRecursion: !!(e && e.extensions && e.extensions.delay_until_recursion),
            groupOverride: !!(e && e.extensions && e.extensions.group_override),
            vectorized: !!(e && e.extensions && e.extensions.vectorized),
            outletName: (e && e.extensions && e.extensions.outlet_name) || '',
            source: e && e.source || 'import'
          }, 'import');
        }),
        regexScripts: Array.isArray(root.extensions && root.extensions.regex_scripts) ? root.extensions.regex_scripts.slice() : regexScripts,
        tavernHelperScripts: Array.isArray(root.extensions && root.extensions.tavern_helper && root.extensions.tavern_helper.scripts)
          ? root.extensions.tavern_helper.scripts.slice()
          : tavernHelperScripts,
        altGreetings: altGreetings,
        avatarBase64: avatarBase64
      };
    }

    // ============================================================
    //  工具函数
    // ============================================================
    function extractJsonObj(text) {
      var m = text.match(/```json\s*([\s\S]*?)\s*```/);
      var o = m ? JSON.parse(m[1]) : JSON.parse(text);
      return (Array.isArray(o) && o.length > 0) ? o[0] : o;
    }
    function extractJsonArray(text) {
      var m = text.match(/```json\s*([\s\S]*?)\s*```/);
      var raw = m ? m[1].trim() : text.trim();
      var p = JSON.parse(raw);
      return Array.isArray(p) ? p : [p];
    }
    function getActivePresetsStr() {
      return parsedPresetList.filter(function(p) { return p.enabled; })
        .map(function(p) { return '[规则: ' + p.name + ']\n' + p.content; }).join('\n\n');
    }
    function sleep(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

    // ============================================================
    //  联网搜索
    // ============================================================
    async function performSearchIfEnabled(userQuery) {
      var sc = window.__searchConfig__;
      if (!sc || !sc.isEnabled()) return { searchText: '', searchResults: null, mode: 'off' };
      var engine = sc.getEngine();
      var customQuery = sc.getCustomQuery();
      var query = customQuery || userQuery;
      var count = sc.getResultCount();
      var lang  = sc.getLang();
      if (engine !== 'none') {
        try {
          var results = await sc.executeSearch(query, count, lang);
          if (results && results.length > 0) {
            cachedSearchResults = results;
            return { searchText: sc.formatForPrompt(results), searchResults: results, mode: 'engine' };
          }
        } catch(err) {
          return { searchText: buildAINativeSearchPrompt(query), searchResults: null, mode: 'ai_fallback', error: err.message };
        }
      }
      return { searchText: buildAINativeSearchPrompt(query), searchResults: null, mode: 'ai_native' };
    }

    function buildAINativeSearchPrompt(query) {
      return '\n\n【🌐 联网搜索指令】：\n'
        + '请使用你的联网搜索能力，搜索以下关键词相关的资料作为创作参考：\n'
        + '搜索词：「' + query + '」\n'
        + '请基于搜索到的真实信息（如果有的话）来丰富你的创作，使设定更加真实、有深度。\n'
        + '如果你不具备联网能力，请忽略此指令，直接基于你的知识库创作。\n';
    }

