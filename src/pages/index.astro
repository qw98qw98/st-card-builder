    function readFileAsArrayBuffer(file) {
      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload = function(ev) { resolve(ev.target.result); };
        reader.onerror = function() { reject(new Error('无法读取文件')); };
        reader.readAsArrayBuffer(file);
      });
    }

    function readFileAsDataURL(file) {
      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload = function(ev) { resolve(String(ev.target.result || '')); };
        reader.onerror = function() { reject(new Error('无法读取文件')); };
        reader.readAsDataURL(file);
      });
    }

    function bindImportDropTarget(target, options) {
      options = options || {};
      if (!target) return;
      var activeClass = options.activeClass || 'iec-drop-active';

      function setActive(active) {
        if (!target.classList) return;
        target.classList.toggle(activeClass, !!active);
      }

      ['dragenter', 'dragover'].forEach(function(eventName) {
        target.addEventListener(eventName, function(e) {
          e.preventDefault();
          e.stopPropagation();
          setActive(true);
          if (e.dataTransfer) e.dataTransfer.dropEffect = 'copy';
        });
      });

      ['dragleave', 'dragend', 'drop'].forEach(function(eventName) {
        target.addEventListener(eventName, function(e) {
          if (eventName === 'drop') {
            e.preventDefault();
            e.stopPropagation();
            setActive(false);

            var dt = e.dataTransfer;
            if (dt && dt.files && dt.files.length && typeof options.onFile === 'function') {
              options.onFile(dt.files[0], e);
              return;
            }
            if (dt && dt.getData) {
              var text = dt.getData('text/plain') || dt.getData('text') || '';
              if (text.trim() && typeof options.onText === 'function') {
                options.onText(text, e);
              }
            }
            return;
          }
          setActive(false);
        });
      });
    }

    function importCardOrWorldbookText(text, fallbackName) {
      var payload = parseWorldbookImportJSON(text);
      if (isPureWorldbookPayload(payload)) {
        applyImportedWorldbook(payload, fallbackName);
        return;
      }
      if (isCharacterCardPayload(payload)) {
        applyJSONFromEditor(payload);
        var card = normalizeImportedCharacterCard(payload);
        showImportStatus('已导入角色卡「' + (card && card.charName ? card.charName : fallbackName || '未命名') + '」', 'ok');
        return;
      }
      applyImportedWorldbook(payload, fallbackName);
    }

    window.__importAssetFromFile = handleImportFile;
    window.__importAssetFromText = importCardOrWorldbookText;
    window.__openImportExportCenter = function() {
      if (typeof window.__setWorkspaceTab__ === 'function') {
        window.__setWorkspaceTab__('core');
      }
      if (importExportCenter && importExportCenter.scrollIntoView) {
        importExportCenter.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    function importPngAsset(file, fallbackName) {
      showImportStatus('⏳ 解析 PNG...', 'info');
      Promise.all([readFileAsArrayBuffer(file), readFileAsDataURL(file)]).then(function(results) {
        try {
          var bytes = new Uint8Array(results[0]);
          var avatarBase64 = results[1];
          var charaJson = extractPNGCharaChunk(bytes);
          if (!charaJson) {
            window.__setImportedAvatar__(avatarBase64, false, avatarBase64);
            showImportStatus('✅ 已更新头像「' + (fallbackName || file.name) + '」', 'ok');
            return;
          }

          var payload = JSON.parse(charaJson);
          if (!isCharacterCardPayload(payload)) {
            throw new Error('PNG 中的角色数据不是有效角色卡');
          }

          applyJSONFromEditor(payload);
          window.__setImportedAvatar__(avatarBase64, false, avatarBase64);
          var card = normalizeImportedCharacterCard(payload);
          showImportStatus(
            '✅ 已导入角色卡「' + (card && card.charName ? card.charName : fallbackName || file.name) + '」并更新头像',
            'ok'
          );
        } catch (err) {
          showImportStatus('❌ PNG 解析失败：' + err.message, 'error');
        }
      }).catch(function(err) {
        showImportStatus('❌ PNG 解析失败：' + err.message, 'error');
      });
    }

    function handleImportFile(file) {
      if (!file) return;
      var ext = (file.name.split('.').pop() || '').toLowerCase();
      var fallbackName = file.name.replace(/\.[^.]+$/, '') || file.name;
      if (ext === 'png') {
        importPngAsset(file, fallbackName);
        return;
      }
      if (ext === 'json') {
        showImportStatus('⏳ 解析 JSON...', 'info');
        file.text().then(function(text) {
          try {
            importCardOrWorldbookText(String(text || ''), fallbackName);
          } catch (err) {
            showImportStatus('❌ 导入失败：' + err.message, 'error');
          }
        }).catch(function(err) {
          showImportStatus('❌ 导入失败：' + err.message, 'error');
        });
        return;
      }
      showImportStatus('❌ 不支持的文件格式，请选择 .json 或 .png', 'error');
    }

    if (importAssetStatus) {
      showImportStatus('等待导入', 'info');
    }

    if (btnImportAssetFile && importAssetInput) {
      btnImportAssetFile.addEventListener('click', function() {
        importAssetInput.value = '';
        importAssetInput.click();
      });
    }

    if (importAssetInput) {
      importAssetInput.addEventListener('change', function(e) {
        var file = e.target.files && e.target.files[0];
        handleImportFile(file);
      });
    }

    if (btnImportAssetText && importAssetText) {
      btnImportAssetText.addEventListener('click', function() {
        try {
          importCardOrWorldbookText(importAssetText.value || '', '粘贴导入');
        } catch (err) {
          showImportStatus('❌ 导入失败：' + err.message, 'error');
        }
      });
    }

    if (importAssetText) {
      bindImportDropTarget(importAssetText.closest('.ie-import-card') || importAssetText.closest('.import-export-center') || importAssetText, {
        onFile: function(file) {
          handleImportFile(file);
        },
        onText: function(text) {
          importAssetText.value = text;
          try {
            importCardOrWorldbookText(text, '拖入内容');
          } catch (err) {
            showImportStatus('❌ 导入失败：' + err.message, 'error');
          }
        }
      });
    }

    if (wbPreviewEmpty) {
      bindImportDropTarget(wbPreviewEmpty, {
        onFile: function(file) {
          handleImportFile(file);
        },
        onText: function(text) {
          try {
            importCardOrWorldbookText(text, '拖入内容');
          } catch (err) {
            showImportStatus('❌ 导入失败：' + err.message, 'error');
          }
        }
      });

      wbPreviewEmpty.addEventListener('click', function(e) {
        var interactive = e.target && e.target.closest && e.target.closest('button, a, input, textarea, select, label');
        if (interactive) return;
        if (typeof window.__openImportExportCenter === 'function') {
          window.__openImportExportCenter();
        }
      });

      wbPreviewEmpty.addEventListener('keydown', function(e) {
        var interactive = e.target && e.target.closest && e.target.closest('button, a, input, textarea, select, label');
        if (interactive) return;
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (typeof window.__openImportExportCenter === 'function') {
            window.__openImportExportCenter();
          }
        }
      });
    }

    if (btnWorldbookImportJump) {
      btnWorldbookImportJump.addEventListener('click', function() {
        if (typeof window.__openImportExportCenter === 'function') {
          window.__openImportExportCenter();
        }
      });
    }

    // ============================================================
    //  工具函数
    // ============================================================
    function extractJsonObj(text) {
      var m = text.match(/```json\s*([\s\S]*?)\s*```/);
      var o = m ? JSON.parse(m[1]) : JSON.parse(text);
      return (Array.isArray(o) && o.length > 0) ? o[0] : o;
    }
    function extractJsonArray(text) {
      var m = text.match(/```json\s*([\s\S]*?)\s*```/);
      var raw = m ? m[1].trim() : text.trim();
      var p = JSON.parse(raw);
      return Array.isArray(p) ? p : [p];
    }
    function sleep(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

    // ============================================================
    //  世界书条目管理
    // ============================================================
    function resetWBForm() {
      editingIndex = -1;
      entryComment.value = '';
      entryContent.value = '';
      entryKeys.value = '';
      entryStrategy.value = 'selective';
      entryPosition.value = '4';
      entryDepth.value = '4';
      entryRole.value = '0';
      entryOrder.value = '100';
      entryProb.value = '100';
      btnAddEntry.textContent = '➕ 保存到列表';
      setWorldbookEditorMeta(-1);
    }

    function loadWorldbookEntryIntoEditor(index) {
      if (index < 0 || index >= worldbookEntries.length) {
        resetWBForm();
        return false;
      }
      editingIndex = index;
      selectedWorldbookIndex = index;
      var e = worldbookEntries[index];
      btnAddEntry.textContent = '💾 确认覆盖';
      entryComment.value = e.comment || '';
      entryContent.value = e.content || '';
      entryKeys.value = (e.keys || []).join(', ');
      entryStrategy.value = e.strategy || 'selective';
      entryPosition.value = String(e.position !== undefined ? e.position : 4);
      entryDepth.value = String(e.depth !== undefined ? e.depth : 4);
      entryRole.value = String(e.role !== undefined ? e.role : 0);
      entryOrder.value = String(e.order !== undefined ? e.order : 100);
      entryProb.value = String(e.prob !== undefined ? e.prob : 100);
      setWorldbookEditorMeta(index);
      return true;
    }

    function editEntry(index) {
      if (index < 0 || index >= worldbookEntries.length) return;
      selectedWorldbookIndex = index;
      if (worldbookMode !== 'edit') {
        setWorldbookMode('edit');
        return;
      }
      loadWorldbookEntryIntoEditor(index);
      renderEntriesList();
    }

    function renderEntriesList() {
      updateWorldbookHeaderCounts();
      updateWorldbookFilterUI();
      setWorldbookEditorMeta(editingIndex);

      if (worldbookMode === 'preview') {
        if (entriesList) entriesList.hidden = true;
        renderWorldbookPreview();
        window.dispatchEvent(new CustomEvent('worldbook-changed'));
        return;
      }
      if (entriesList) entriesList.hidden = false;

      var visibleEntries = worldbookEntries
        .map(function(entry, index) { return { entry: entry, index: index }; })
        .filter(function(item) {
          if (worldbookBrowseFilter === 'all') return true;
          return (item.entry.source || 'manual') === worldbookBrowseFilter;
        });

      entriesList.innerHTML = '';

      if (!visibleEntries.length) {
        var emptyMessage = worldbookEntries.length
          ? '当前筛选下没有条目，换个来源标签看看。'
          : '暂无条目，先从左侧生成或手动添加一条。';
        entriesList.innerHTML = '<div class="wb-entry-empty">' + emptyMessage + '</div>';
        if (worldbookMode === 'preview') {
          renderWorldbookPreview();
        } else {
          setPreviewCopyButtonsEnabled(false);
        }
        return;
      }

      var posMap = ["0前","1后","2前EM","3后EM","4深度","5前AN","6后AN"];
      visibleEntries.forEach(function(item) {
        var entry = item.entry;
        var index = item.index;
        var isSk = (entry.content || '').length < 60;
        var source = entry.source || 'manual';
        var preview = (entry.content || '').replace(/\s+/g, ' ').trim();
        if (preview.length > 120) preview = preview.slice(0, 120) + '…';
        var keysText = (entry.keys || []).join('、') || '无触发词';
        var sourceClass = getWorldbookSourceClass(source);
        var sourceLabel = getWorldbookSourceLabel(source);
        var skBadge = isSk ? '<span class="wb-source-pill wb-source-skeleton">骨架</span>' : '';
        var safeComment = escapeHTML(entry.comment || '未命名');
        var safePreview = escapeHTML(preview || '（空内容）');
        var safeKeys = escapeHTML(keysText);
        var safeMeta = '位置: ' + escapeHTML(posMap[entry.position] || String(entry.position)) + ' · 顺序: ' + escapeHTML(String(entry.order)) + ' · 深度: ' + escapeHTML(String(entry.depth)) + ' · 优先级: ' + escapeHTML(String(entry.prob));
        var div = document.createElement('div');
        div.className = 'wb-entry fade-in' + (selectedWorldbookIndex === index ? ' is-selected' : '');
        div.setAttribute('data-worldbook-index', String(index));
        div.innerHTML =
          '<div class="wb-entry-body" data-worldbook-select="' + index + '">' +
            '<div class="wb-entry-top">' +
              '<div>' +
                '<h4 class="wb-entry-title">' + safeComment + '</h4>' +
                '<div class="wb-entry-meta">' + safeMeta + ' · <span class="wb-source-pill ' + sourceClass + '">' + sourceLabel + '</span>' + (isSk ? ' · <span class="wb-source-pill wb-source-skeleton">骨架</span>' : '') + '</div>' +
              '</div>' +
              '<div class="wb-entry-top-badges">' + skBadge + '</div>' +
            '</div>' +
            '<div class="wb-entry-preview">' + safePreview + '</div>' +
            '<div class="wb-entry-keys">触发词：' + safeKeys + '</div>' +
          '</div>' +
          '<div class="wb-entry-actions">' +
            '<button class="btn wb-btn-edit" type="button" data-worldbook-index="' + index + '">✏️ 编辑</button>' +
            '<button class="btn wb-btn-delete" type="button" data-worldbook-index="' + index + '">🗑️ 删除</button>' +
          '</div>' +
          '';
        entriesList.appendChild(div);
      });

      entriesList.querySelectorAll('[data-worldbook-select]').forEach(function(node) {
        node.addEventListener('click', function(e) {
          var idx = parseInt(e.currentTarget.getAttribute('data-worldbook-select'), 10);
          if (isNaN(idx)) return;
          if (worldbookMode === 'preview') {
            selectedWorldbookIndex = idx;
            renderEntriesList();
            return;
          }
          editEntry(idx);
        });
      });

      entriesList.querySelectorAll('.wb-btn-edit').forEach(function(b) {
        b.addEventListener('click', function(e) {
          e.stopPropagation();
          editEntry(parseInt(e.currentTarget.getAttribute('data-worldbook-index'), 10));
        });
      });

      entriesList.querySelectorAll('.wb-btn-delete').forEach(function(b) {
        b.addEventListener('click', function(e) {
          e.stopPropagation();
          var idx = parseInt(e.currentTarget.getAttribute('data-worldbook-index'), 10);
          worldbookEntries.splice(idx, 1);
          if (editingIndex === idx) {
            resetWBForm();
          } else if (editingIndex > idx) {
            editingIndex--;
          }
          if (selectedWorldbookIndex === idx) {
            selectedWorldbookIndex = -1;
          } else if (selectedWorldbookIndex > idx) {
            selectedWorldbookIndex--;
          }
          renderEntriesList();
          debouncedUpdateAndSave();
        });
      });
      if (worldbookMode === 'preview') {
        renderWorldbookPreview();
      } else {
        setPreviewCopyButtonsEnabled(false);
      }
      // 通知审计官：世界书条目已变化
      window.dispatchEvent(new CustomEvent('worldbook-changed'));
    }

    btnAddEntry.addEventListener('click', function() {
      if (!entryContent.value.trim()) return alert('内容不能为空！');
      var savedIndex = editingIndex >= 0 ? editingIndex : worldbookEntries.length;
      var ne = normalizeWorldbookEntry({
        comment: entryComment.value.trim(),
        content: entryContent.value.trim(),
        keys: entryKeys.value.split(',').map(function(k) { return k.trim(); }).filter(function(k) { return k; }),
        strategy: entryStrategy.value,
        position: safeInt(entryPosition.value, 4),
        depth: safeInt(entryDepth.value, 4),
        role: safeInt(entryRole.value, 0),
        order: safeInt(entryOrder.value, 100),
        prob: safeInt(entryProb.value, 100),
        source: 'manual'
      }, 'manual');
      if (editingIndex >= 0) worldbookEntries[editingIndex] = ne; else worldbookEntries.push(ne);
      selectedWorldbookIndex = savedIndex;
      worldbookBrowseFilter = 'manual';
      updateWorldbookFilterUI();
      resetWBForm();
      renderEntriesList();
      debouncedUpdateAndSave();
    });

    // ============================================================
    //  JSON 生成 (wrappers around imported functions)
    // ============================================================
    function downloadJsonFile(payload, filename) {
      var j = JSON.stringify(payload, null, 2);
      var a = document.createElement('a');
      a.href = 'data:text/json;charset=utf-8,' + encodeURIComponent(j);
      a.download = filename;
      a.click();
    }

    // ============================================================
    //  预览 & 联动 & 初始化
    // ============================================================
    function updatePreview() {
      return;
    }

    [charName, wbName, charDesc, firstMes, creatorNotes].forEach(function(el) {
      el.addEventListener('input', debouncedUpdateAndSave);
    });

    window.generateSillyTavernJSON = function() { return generateSillyTavernJSON(buildExportContext()); };
    window.generateVanillaCharacterJSON = function() { return generateVanillaCharacterJSON(buildExportContext()); };
    window.downloadWorldbookMarkdown = function() {
      var nameSource = (wbName && wbName.value && wbName.value.trim()) || (charName && charName.value && charName.value.trim()) || 'worldbook';
      downloadWorldbookMarkdown(nameSource, worldbookEntries);
    };
    window.exportCardByFormat = function(format) {
      if (format === 'vanilla') {
        downloadJsonFile(generateVanillaCharacterJSON(buildExportContext()), (charName.value || 'card') + '.json');
        return;
      }
      if (format === 'st') {
        downloadJsonFile(generateSillyTavernJSON(buildExportContext()), (charName.value || 'card') + '.json');
        return;
      }
      if (format === 'worldbook-md') {
        if (!worldbookEntries.length) return alert('世界书为空，暂无可导出的词条。');
        var nameSource = (wbName && wbName.value && wbName.value.trim()) || (charName && charName.value && charName.value.trim()) || 'worldbook';
        downloadWorldbookMarkdown(nameSource, worldbookEntries);
        return;
      }
    };

    var initialWorldbookMode = 'edit';
    try {
      var storedWorldbookMode = localStorage.getItem(WB_MODE_KEY);
      if (storedWorldbookMode === 'preview' || storedWorldbookMode === 'edit') {
        initialWorldbookMode = storedWorldbookMode;
      }
    } catch (err) {}

    var drafts = getAllDrafts();
    var lastId = localStorage.getItem(CURRENT_KEY);
    if (lastId && drafts[lastId]) loadDraft(lastId);
    else if (Object.keys(drafts).length > 0) loadDraft(Object.keys(drafts)[0]);
    else btnNewDraft.click();
    setWorldbookMode(initialWorldbookMode, true);

  </script>
</Layout>
