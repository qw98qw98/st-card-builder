        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
        },
        body: '{}'
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        // RPC 返回的是一个数字
        if (typeof data === 'number') {
          numEl.textContent = data.toLocaleString();
          sessionStorage.setItem(SESSION_KEY, '1');
        } else {
          numEl.textContent = '--';
        }
      })
      .catch(function() {
        numEl.textContent = '--';
      });
    })();

    var drafts = getAllDrafts();
    var lastId = localStorage.getItem(CURRENT_KEY);
    if (lastId && drafts[lastId]) loadDraft(lastId);
    else if (Object.keys(drafts).length > 0) loadDraft(Object.keys(drafts)[0]);
    else btnNewDraft.click();
    setWorldbookMode(initialWorldbookMode, true);

  </script>
</Layout>
