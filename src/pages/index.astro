    function movePreviewSelection(delta) {
      var visible = getVisibleWorldbookItems();
      if (!visible.length) return;
      var current = getPreviewSelectionIndex(visible);
      if (current < 0) current = 0;
      var next = current + delta;
      if (next < 0) next = 0;
      if (next >= visible.length) next = visible.length - 1;
      selectPreviewIndex(visible[next].index, { focus: true });
    }

    function jumpPreviewSelection(index) {
      var visible = getVisibleWorldbookItems();
      if (!visible.length) return;
      if (index < 0) index = 0;
