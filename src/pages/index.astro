        };
        if (e.outletName) ext.outlet_name = e.outletName;

        return {
          uid: i,
          keys: keys,
          secondary_keys: secondaryKeys,
          comment: comment,
          content: content,
          constant: isConstant,
          vectorized: !!e.vectorized,
          selective: isSelective,
