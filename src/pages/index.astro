      : (root.statusBlockConfig && typeof root.statusBlockConfig === 'object'
        ? root.statusBlockConfig
        : (json.statusBlockConfig && typeof json.statusBlockConfig === 'object' ? json.statusBlockConfig : { description: '' })),
    presetStatusBlock: String(card.presetStatusBlock || root.presetStatusBlock || json.presetStatusBlock || '').trim(),
    characterBookDescription: String(importedCharacterBook.description || '').trim(),
    characterBookScanDepth: importedCharacterBook.scan_depth !== undefined ? safeInt(importedCharacterBook.scan_depth, 3) : 3,
    characterBookTokenBudget: importedCharacterBook.token_budget !== undefined ? safeInt(importedCharacterBook.token_budget, 1800000000) : 1800000000,
    characterBookRecursiveScanning: importedCharacterBook.recursive_scanning !== undefined ? !!importedCharacterBook.recursive_scanning : true
  };
  importedCardMetaStore.set(_importedCardMeta);
