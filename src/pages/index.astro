    creator: String(card.creator || root.creator || '').trim(),
    characterVersion: String(card.characterVersion || root.character_version || '').trim(),
    nickname: String(card.nickname || root.nickname || '').trim(),
    gender: String(card.gender || root.gender || '').trim(),
    statusBlockConfig: card.statusBlockConfig && typeof card.statusBlockConfig === 'object'
