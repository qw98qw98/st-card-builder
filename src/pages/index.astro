    // ============================================================
    //  世界书工具
    // ============================================================
    function escapeHTML(str) {
      return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function safeInt(value, fallback) {
      var num = parseInt(value, 10);
      return isNaN(num) ? fallback : num;
    }

    function normalizeWorldbookEntry(entry, fallbackSource) {
      entry = entry || {};
      var extensions = entry.extensions || {};
      return {
        comment: entry.comment || '',
        content: entry.content || '',
        keys: Array.isArray(entry.keys) ? entry.keys.slice() : [],
        secondaryKeys: Array.isArray(entry.secondaryKeys)
          ? entry.secondaryKeys.slice()
          : Array.isArray(entry.secondary_keys)
