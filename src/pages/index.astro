---
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
import WorkspaceNav from '../components/WorkspaceNav.astro';
import ImportExportCenter from '../components/ImportExportCenter.astro';
import CharacterPanel from '../components/CharacterPanel.astro';
import WorldbookPanel from '../components/WorldbookPanel.astro';
import PromptLayoutPanel from '../components/PromptLayoutPanel.astro';
---

<Layout title="然然工坊">
  <AppHeader title="然然工坊" />

  <WorkspaceNav tabs={[
    { target: 'core', label: '核心设置', selected: true },
    { target: 'worldbook', label: '世界书' },
    { target: 'prompt-layout', label: 'Prompt 排布' },
  ]} />

  <div class="app-container">
    <section class="workspace-section" data-workspace-section="core">
      <div class="workspace-section-header">
        <div>
          <h2 class="workspace-section-title">核心设置</h2>
          <p class="workspace-section-desc">导入导出、角色基础信息与草稿管理</p>
        </div>
      </div>
      <ImportExportCenter />
      <div class="workspace-grid workspace-grid-core">
        <CharacterPanel />
      </div>
    </section>

    <section class="workspace-section" data-workspace-section="worldbook" hidden>
      <div class="workspace-section-header">
        <div>
          <h2 class="workspace-section-title">世界书</h2>
        </div>
      </div>
      <div class="workspace-stack">
        <WorldbookPanel />
      </div>
    </section>

    <section class="workspace-section" data-workspace-section="prompt-layout" hidden>
      <div class="workspace-section-header">
        <div>
          <h2 class="workspace-section-title">Prompt 排布</h2>
          <p class="workspace-section-desc">可视化角色卡 Prompt 在上下文中的排布顺序，评估 Prompt 工程设计</p>
        </div>
      </div>
      <div class="workspace-stack">
        <PromptLayoutPanel />
      </div>
    </section>
  </div>

  <script>
    import { initWorkspaceTabs } from '../scripts/workspace-tabs';
    initWorkspaceTabs();
  </script>

  <script>
    import { escapeHTML } from '../scripts/utils/escape-html';
    import { safeInt } from '../scripts/utils/safe-int';
    import { normalizeWorldbookEntry } from '../scripts/worldbook/normalize';
    import { getFieldInfo, validateField, validateFullJSON } from '../scripts/field-dict';
    import { extractWorldbookImportJSON, parseWorldbookImportJSON, getWorldbookImportName, getImportedWorldbookMeta, getImportedWorldbookEntries } from '../scripts/worldbook/import';
    import { getCardRootPayload, isCharacterCardPayload, isPureWorldbookPayload, normalizeImportedCharacterCard } from '../scripts/card-normalize';
    import { getWorldbookSourceLabel, getWorldbookSourceClass, cleanWorldbookTitle, normalizeWorldbookTextBlock, makePreviewCopyText, buildWorldbookMarkdown, downloadWorldbookMarkdown } from '../scripts/worldbook-helpers';
    import { buildExportWorldbookEntries, buildExportCharacterBook, generateSillyTavernJSON, generateVanillaCharacterJSON } from '../scripts/json-generate';
    import type { ExportContext } from '../scripts/json-generate';
    import { createTextChunk, extractPNGCharaChunk } from '../scripts/utils/png-chunk';
    import {
      altGreetings as altGreetingsStore,
      importedCardMeta as importedCardMetaStore,
      importedWorldbookMeta as importedWorldbookMetaStore,
      statusBarData as statusBarDataStore,
      registerSaveHandler,
    } from '../stores/card-store';

    // ============================================================
    //  Export context helper
    // ============================================================
    function buildExportContext(): ExportContext {
      return {
        charName: charName.value.trim(),
        charDesc: charDesc.value.trim(),
        firstMes: firstMes.value.trim(),
        creatorNotes: creatorNotes.value.trim(),
        wbName: wbName.value.trim(),
        worldbookEntries: worldbookEntries,
        altGreetings: altGreetingsStore.get(),
        importedCardMeta: importedCardMetaStore.get(),
        importedWorldbookMeta: importedWorldbookMetaStore.get(),
      };
    }

    // ============================================================
    //  Field dict bridge
    // ============================================================
    window.__fieldDict__ = { getFieldInfo: getFieldInfo, validateFullJSON: validateFullJSON };

    var draftSelect          = document.getElementById('draftSelect');
    var btnNewDraft          = document.getElementById('btnNewDraft');
    var btnDeleteDraft       = document.getElementById('btnDeleteDraft');
    var saveIndicator        = document.getElementById('saveIndicator');
    var avatarImg            = document.getElementById('avatarImg');
    var avatarPlaceholder    = document.getElementById('avatarPlaceholder');
    var importAssetInput     = document.getElementById('importAssetInput');
    var btnImportAssetFile   = document.getElementById('btnImportAssetFile');
    var btnImportAssetText   = document.getElementById('btnImportAssetText');
    var importAssetText      = document.getElementById('importAssetText');
    var importAssetStatus    = document.getElementById('importAssetStatus');
    var btnExportMenu        = document.getElementById('btnExportMenu');
    var exportFormatMenu     = document.getElementById('exportFormatMenu');
    var btnExportPNG         = document.getElementById('btnExportPNG');
    var btnWorldbookImportJump = document.getElementById('btnWorldbookImportJump');
    var importExportCenter   = document.getElementById('importExportCenter');
    var charName             = document.getElementById('charName');
    var wbName               = document.getElementById('wbName');
    var charDesc             = document.getElementById('charDesc');
    var firstMes             = document.getElementById('firstMes');
    var creatorNotes         = document.getElementById('creatorNotes');
    var entryComment         = document.getElementById('entryComment');
    var entryContent         = document.getElementById('entryContent');
    var entryKeys            = document.getElementById('entryKeys');
    var entryStrategy        = document.getElementById('entryStrategy');
    var entryPosition        = document.getElementById('entryPosition');
    var entryDepth           = document.getElementById('entryDepth');
    var entryRole            = document.getElementById('entryRole');
    var entryOrder           = document.getElementById('entryOrder');
    var entryProb            = document.getElementById('entryProb');
    var btnAddEntry          = document.getElementById('btnAddEntry');
    var entriesList          = document.getElementById('entriesList');
    var wbShell              = document.querySelector('.wb-shell');
    var wbEditorHint         = document.getElementById('wbEditorHint');
    var wbEditorSource       = document.getElementById('wbEditorSource');
    var wbTotalCount         = document.getElementById('wbTotalCount');
    var wbGenCount           = document.getElementById('wbGenCount');
    var wbManualCount        = document.getElementById('wbManualCount');
    var wbImportCount        = document.getElementById('wbImportCount');
    var wbFilterButtons      = Array.prototype.slice.call(document.querySelectorAll('[data-wb-filter]'));
    var wbModeButtons        = Array.prototype.slice.call(document.querySelectorAll('[data-wb-mode]'));
    var wbModePanels         = Array.prototype.slice.call(document.querySelectorAll('[data-wb-mode-panel]'));
    var wbPreviewSummary     = document.getElementById('wbPreviewSummary');
    var wbPreviewNotice      = document.getElementById('wbPreviewNotice');
    var wbPreviewEmpty       = document.getElementById('wbPreviewEmpty');
    var wbPreviewEmptyTitle  = document.getElementById('wbPreviewEmptyTitle');
    var wbPreviewEmptyDesc   = document.getElementById('wbPreviewEmptyDesc');
    var wbPreviewView        = document.getElementById('wbPreviewView');
    var wbPreviewListCount   = document.getElementById('wbPreviewListCount');
    var wbPreviewSource      = document.getElementById('wbPreviewSource');
    var wbPreviewStrategy    = document.getElementById('wbPreviewStrategy');
    var wbPreviewPosition    = document.getElementById('wbPreviewPosition');
    var wbPreviewDepth       = document.getElementById('wbPreviewDepth');
    var wbPreviewOrder       = document.getElementById('wbPreviewOrder');
    var wbPreviewProb        = document.getElementById('wbPreviewProb');
    var wbPreviewTitle       = document.getElementById('wbPreviewTitle');
    var wbPreviewKeys        = document.getElementById('wbPreviewKeys');
    var wbPreviewContent     = document.getElementById('wbPreviewContent');

    // ============================================================
    //  状态
    // ============================================================
    var worldbookEntries     = [];
    var regexScripts         = [];
    var tavernHelperScripts  = [];  // ScriptTree[] — 酒馆助手脚本
    var currentAvatarSrc     = "";
    var currentAvatarExportBase64 = "";
    var currentDraftId       = "";
    var editingIndex         = -1;
    var selectedWorldbookIndex = -1;
    var worldbookBrowseFilter = 'all';
    var worldbookMode        = 'edit';
    var previewTypeahead     = '';
    var previewTypeaheadTimer = null;

    if (!altGreetingsStore.get().length) altGreetingsStore.set([]);
    // importedCardMeta / importedWorldbookMeta defaults are already null in the store

    var DRAFTS_KEY  = "st_v3_builder_drafts";
    var CURRENT_KEY = "st_v3_builder_current_id";
    var WB_MODE_KEY = "st_v3_worldbook_mode";

    function getWorldbookEntriesForSource(source) {
      if (source === 'all') return worldbookEntries.slice();
      return worldbookEntries.filter(function(entry) {
        return (entry.source || 'manual') === source;
      });
    }

    function updateWorldbookHeaderCounts() {
      var counts = { ai: 0, manual: 0, import: 0 };
      worldbookEntries.forEach(function(entry) {
        var source = entry.source || 'manual';
        if (source === 'ai') counts.ai++;
        else if (source === 'import') counts.import++;
        else counts.manual++;
      });
      if (wbTotalCount) wbTotalCount.textContent = worldbookEntries.length + ' 条';
      if (wbGenCount) wbGenCount.textContent = '生成 ' + counts.ai;
      if (wbManualCount) wbManualCount.textContent = '手动 ' + counts.manual;
      if (wbImportCount) wbImportCount.textContent = '导入 ' + counts.import;

      wbFilterButtons.forEach(function(btn) {
        var filter = btn.getAttribute('data-wb-filter');
        var countEl = btn.querySelector('[data-filter-count]');
        if (!countEl) return;
        var count = filter === 'all' ? worldbookEntries.length : counts[filter] || 0;
        countEl.textContent = count;
      });
    }

    function updateWorldbookFilterUI() {
      wbFilterButtons.forEach(function(btn) {
        var active = btn.getAttribute('data-wb-filter') === worldbookBrowseFilter;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function setWorldbookEditorMeta(index) {
      if (!wbEditorHint || !wbEditorSource) return;
      if (index === undefined || index === null || index < 0 || index >= worldbookEntries.length) {
        wbEditorHint.textContent = '点击左侧条目后在这里修改，未选中时会作为新条目保存。';
        wbEditorSource.textContent = '新建';
        wbEditorSource.className = 'wb-pill wb-pill-neutral';
        return;
      }
      var entry = worldbookEntries[index];
      wbEditorHint.textContent = '正在编辑：' + (entry.comment || '未命名条目');
      wbEditorSource.textContent = getWorldbookSourceLabel(entry.source || 'manual');
      wbEditorSource.className = 'wb-pill ' + getWorldbookSourceClass(entry.source || 'manual');
    }

    function setWorldbookMode(mode, skipStore) {
      worldbookMode = mode === 'preview' ? 'preview' : 'edit';

      wbModeButtons.forEach(function(btn) {
        var active = btn.getAttribute('data-wb-mode') === worldbookMode;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      wbModePanels.forEach(function(panel) {
        var active = panel.getAttribute('data-wb-mode-panel') === worldbookMode;
        panel.hidden = !active;
        panel.setAttribute('aria-hidden', active ? 'false' : 'true');
      });

      if (wbShell) {
        wbShell.classList.toggle('is-preview-mode', worldbookMode === 'preview');
      }
      if (entriesList) {
        entriesList.hidden = worldbookMode === 'preview';
      }
      Array.prototype.slice.call(document.querySelectorAll('.area-statusbar, .area-auditor')).forEach(function(panel) {
        panel.hidden = worldbookMode === 'preview';
        panel.setAttribute('aria-hidden', worldbookMode === 'preview' ? 'true' : 'false');
      });

      if (!skipStore) {
        try { localStorage.setItem(WB_MODE_KEY, worldbookMode); } catch (err) {}
      }

      if (worldbookMode === 'edit') {
        if (selectedWorldbookIndex >= 0 && selectedWorldbookIndex < worldbookEntries.length) {
          loadWorldbookEntryIntoEditor(selectedWorldbookIndex);
        } else {
          resetWBForm();
        }
      }

      renderEntriesList();
      if (worldbookMode === 'preview' && wbPreviewView) {
        setTimeout(function() {
          try {
            wbPreviewView.focus({ preventScroll: true });
          } catch (err) {
            wbPreviewView.focus();
          }
        }, 0);
      }
    }

    function getVisibleWorldbookItems() {
      return worldbookEntries
        .map(function(entry, index) { return { entry: entry, index: index }; })
        .filter(function(item) {
          if (worldbookBrowseFilter === 'all') return true;
          return (item.entry.source || 'manual') === worldbookBrowseFilter;
        });
    }

    function getPreviewFocusIndex() {
      var visible = getVisibleWorldbookItems();
      if (selectedWorldbookIndex >= 0 && selectedWorldbookIndex < worldbookEntries.length) {
        var selectedItem = worldbookEntries[selectedWorldbookIndex];
        if (worldbookBrowseFilter === 'all' || (selectedItem && (selectedItem.source || 'manual') === worldbookBrowseFilter)) {
          return selectedWorldbookIndex;
        }
      }
      if (editingIndex >= 0 && editingIndex < worldbookEntries.length) {
        var editingItem = worldbookEntries[editingIndex];
        if (worldbookBrowseFilter === 'all' || (editingItem && (editingItem.source || 'manual') === worldbookBrowseFilter)) {
          return editingIndex;
        }
      }
      return visible.length ? visible[0].index : -1;
    }

    function showImportStatus(message, tone) {
      if (!importAssetStatus) return;
      var map = {
        info: { color: '#7dd3fc', bg: 'rgba(56,189,248,0.08)', border: 'rgba(56,189,248,0.18)' },
        ok: { color: '#34d399', bg: 'rgba(16,185,129,0.12)', border: 'rgba(16,185,129,0.28)' },
        error: { color: '#fca5a5', bg: 'rgba(239,68,68,0.08)', border: 'rgba(239,68,68,0.2)' }
      };
      var c = map[tone] || map.info;
      importAssetStatus.style.color = c.color;
      importAssetStatus.style.background = c.bg;
      importAssetStatus.style.borderColor = c.border;
      importAssetStatus.textContent = message;
    }

    function commitImportedState(options) {
      options = options || {};
      if (options.resetEditor !== false) {
        setWorldbookEditorMeta(-1);
      }
      updateWorldbookFilterUI();
      renderEntriesList();
      updatePreview();
      saveCurrentDraft();
    }

    function applyImportedWorldbook(payload, fallbackName) {
      var entries = getImportedWorldbookEntries(payload);
      if (!entries.length) {
        throw new Error('没有找到可导入的世界书条目');
      }

      var importedName = getWorldbookImportName(payload, fallbackName);
      var importedMeta = getImportedWorldbookMeta(payload);
      worldbookEntries = entries;
      if (importedName) {
        wbName.value = importedName;
      }
      if (!creatorNotes.value.trim() && importedMeta.worldbookDescription) {
        creatorNotes.value = importedMeta.worldbookDescription;
      }
      editingIndex = -1;
      selectedWorldbookIndex = -1;
      worldbookBrowseFilter = 'all';
      resetWBForm();
      window.__importedWorldbookMeta__ = importedMeta;
      importedWorldbookMetaStore.set(importedMeta);
      updateWorldbookFilterUI();
      setWorldbookEditorMeta(-1);
      renderEntriesList();
      updatePreview();
      saveCurrentDraft();
      showImportStatus(
        '已导入 ' + String(entries.length) + (Array.isArray(payload && payload.qrList) && payload.qrList.length ? ' 个快速回复按钮' : ' 条世界书'),
        'ok'
      );
    }

    function getPreviewVisibleIndex(visible, globalIndex) {
      for (var i = 0; i < visible.length; i++) {
        if (visible[i].index === globalIndex) return i;
      }
      return -1;
    }

    function getPreviewSelectionIndex(visible) {
      var current = getPreviewVisibleIndex(visible, selectedWorldbookIndex);
      if (current >= 0) return current;
      current = getPreviewVisibleIndex(visible, editingIndex);
      if (current >= 0) return current;
      return visible.length ? 0 : -1;
    }

    function setPreviewNotice(text) {
      if (wbPreviewNotice) {
        wbPreviewNotice.textContent = text || '';
      }
    }

    function copyWorldbookText(text, statusLabel) {
      if (!text) return Promise.resolve(false);
      var done = function(ok) {
        setPreviewNotice(ok ? (statusLabel || '已复制') : '复制失败，请手动全选复制');
        return ok;
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text).then(function() { return done(true); }).catch(function() { return done(false); });
      }
      try {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', 'readonly');
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        var ok = document.execCommand('copy');
        document.body.removeChild(ta);
        return Promise.resolve(done(ok));
      } catch (err) {
        return Promise.resolve(done(false));
      }
    }

    function setPreviewCopyButtonsEnabled(enabled) {
      [
        btnCopyPreviewTitle,
        btnCopyPreviewKeys,
        btnCopyPreviewContent,
        btnCopyPreviewAll
      ].forEach(function(btn) {
        if (btn) btn.disabled = !enabled;
      });
    }

    function focusPreviewList() {
      if (!wbPreviewView) return;
      try {
        wbPreviewView.focus({ preventScroll: true });
      } catch (err) {
        wbPreviewView.focus();
      }
    }

    function selectPreviewIndex(index, opts) {
      opts = opts || {};
      if (index < 0 || index >= worldbookEntries.length) return;
      selectedWorldbookIndex = index;
      renderWorldbookPreview();
      if (opts.focus && wbPreviewView) {
        focusPreviewList();
      }
    }

    function movePreviewSelection(delta) {
      var visible = getVisibleWorldbookItems();
      if (!visible.length) return;
      var current = getPreviewSelectionIndex(visible);
      if (current < 0) current = 0;
      var next = current + delta;
      if (next < 0) next = 0;
      if (next >= visible.length) next = visible.length - 1;
      selectPreviewIndex(visible[next].index, { focus: true });
    }

    function jumpPreviewSelection(index) {
      var visible = getVisibleWorldbookItems();
      if (!visible.length) return;
      if (index < 0) index = 0;
      if (index >= visible.length) index = visible.length - 1;
      selectPreviewIndex(visible[index].index, { focus: true });
    }

    function findPreviewMatch(query) {
      var visible = getVisibleWorldbookItems();
      if (!visible.length) return -1;
      var needle = String(query || '').trim().toLowerCase();
      if (!needle) return -1;
      var start = getPreviewSelectionIndex(visible);
      var order = visible.slice(start + 1).concat(visible.slice(0, start + 1));
      for (var i = 0; i < order.length; i++) {
        var item = order[i].entry || {};
        var haystack = [
          item.comment || '',
          Array.isArray(item.keys) ? item.keys.join(' ') : '',
          item.content || ''
        ].join(' ').toLowerCase();
        if (haystack.indexOf(needle) >= 0) {
          return order[i].index;
        }
      }
      return -1;
    }

    function handlePreviewKeydown(event) {
      if (worldbookMode !== 'preview') return;
      if (!wbPreviewView || wbPreviewView.hidden) return;
      var target = event.target || document.activeElement;
      if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable)) {
        return;
      }
      var visible = getVisibleWorldbookItems();
      if (!visible.length) return;

      if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') {
        event.preventDefault();
        movePreviewSelection(-1);
        return;
      }
      if (event.key === 'ArrowDown' || event.key === 'ArrowRight') {
        event.preventDefault();
        movePreviewSelection(1);
        return;
      }
      if (event.key === 'Home') {
        event.preventDefault();
        jumpPreviewSelection(0);
        return;
      }
      if (event.key === 'End') {
        event.preventDefault();
        jumpPreviewSelection(visible.length - 1);
        return;
      }
      if (event.key === 'PageUp') {
        event.preventDefault();
        movePreviewSelection(-Math.max(1, Math.floor(visible.length / 6)));
        return;
      }
      if (event.key === 'PageDown') {
        event.preventDefault();
        movePreviewSelection(Math.max(1, Math.floor(visible.length / 6)));
        return;
      }
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        renderWorldbookPreview();
        return;
      }
      if (event.ctrlKey || event.metaKey || event.altKey || event.isComposing || event.key.length !== 1) {
        return;
      }
      previewTypeahead += event.key;
      clearTimeout(previewTypeaheadTimer);
      previewTypeaheadTimer = setTimeout(function() {
        previewTypeahead = '';
      }, 650);
      var matched = findPreviewMatch(previewTypeahead);
      if (matched >= 0) {
        event.preventDefault();
        selectedWorldbookIndex = matched;
        renderWorldbookPreview();
        focusPreviewList();
        return;
      }
      if (previewTypeahead.length > 1) {
        var singleMatch = findPreviewMatch(event.key);
        if (singleMatch >= 0) {
          event.preventDefault();
          selectedWorldbookIndex = singleMatch;
          renderWorldbookPreview();
          focusPreviewList();
        }
      }
    }

    if (wbPreviewView) {
      wbPreviewView.addEventListener('keydown', handlePreviewKeydown);
    }

    function bindPreviewCopyButton(btn, label, textFactory) {
      if (!btn) return;
      btn.addEventListener('click', function() {
        var idx = getPreviewFocusIndex();
        if (idx < 0 || idx >= worldbookEntries.length) return;
        copyWorldbookText(textFactory(worldbookEntries[idx]), label);
      });
    }

    function setPreviewDetail(entry, index, visibleCount, posMap) {
      entry = entry || {};
      if (wbPreviewSummary) {
        var visibleIndex = 0;
        if (index >= 0) {
          visibleIndex = getPreviewVisibleIndex(getVisibleWorldbookItems(), index);
        }
        wbPreviewSummary.textContent = visibleCount
          ? ('当前预览共 ' + visibleCount + ' 条，正在查看第 ' + String(visibleIndex >= 0 ? visibleIndex + 1 : 1) + ' 条：' + (entry.comment || '未命名条目') + '。')
          : '当前筛选没有可预览条目。';
      }
      if (wbPreviewListCount) {
        wbPreviewListCount.textContent = visibleCount + ' 条';
      }
      if (wbPreviewSource) {
        var source = entry.source || 'manual';
        wbPreviewSource.textContent = getWorldbookSourceLabel(source);
        wbPreviewSource.className = 'wb-pill ' + getWorldbookSourceClass(source);
      }
      if (wbPreviewStrategy) {
        wbPreviewStrategy.textContent = '策略 · ' + (entry.strategy || 'selective');
      }
      if (wbPreviewPosition) {
        wbPreviewPosition.textContent = '位置 · ' + (posMap[entry.position] || String(entry.position !== undefined ? entry.position : 4));
      }
      if (wbPreviewDepth) {
        wbPreviewDepth.textContent = '深度 · ' + String(entry.depth !== undefined ? entry.depth : 4);
      }
      if (wbPreviewOrder) {
        wbPreviewOrder.textContent = '顺序 · ' + String(entry.order !== undefined ? entry.order : 100);
      }
      if (wbPreviewProb) {
        wbPreviewProb.textContent = '优先级 · ' + String(entry.prob !== undefined ? entry.prob : 100);
      }
      if (wbPreviewTitle) {
        wbPreviewTitle.textContent = entry.comment || '未命名条目';
      }
      if (wbPreviewKeys) {
        var keys = Array.isArray(entry.keys) ? entry.keys : [];
        wbPreviewKeys.innerHTML = keys.length
          ? keys.map(function(key) {
              return '<span class="wb-preview-key-chip">' + escapeHTML(key) + '</span>';
            }).join('')
          : '<span class="wb-preview-key-chip">无触发词</span>';
      }
      if (wbPreviewContent) {
        wbPreviewContent.textContent = entry.content || '（空内容）';
      }
      setPreviewNotice('键盘：↑↓ 切换，Home/End 跳转，输入首字快速定位。');
    }

    function renderWorldbookPreview() {
      if (!wbPreviewEmpty || !wbPreviewView) return;
      var visible = getVisibleWorldbookItems();
      var focusIndex = getPreviewFocusIndex();
      var posMap = ["0前","1后","2前EM","3后EM","4深度","5前AN","6后AN"];

      if (entriesList) {
        entriesList.hidden = true;
      }

      if (wbPreviewListCount) {
        wbPreviewListCount.textContent = visible.length + ' 条';
      }

      if (!visible.length) {
        wbPreviewEmpty.hidden = false;
        wbPreviewView.hidden = true;
        wbPreviewView.innerHTML = '';
        setPreviewCopyButtonsEnabled(false);
        setPreviewDetail({}, -1, 0, posMap);
        setPreviewNotice(worldbookEntries.length ? '切换来源标签，或直接拖入文件继续导入。' : '拖入 .json 或 .png 就能直接导入。');
        if (wbPreviewEmptyTitle) {
          wbPreviewEmptyTitle.textContent = worldbookEntries.length ? '当前筛选没有条目' : '拖入文件即可导入';
        }
        if (wbPreviewEmptyDesc) {
          wbPreviewEmptyDesc.textContent = worldbookEntries.length
            ? '切换来源标签，或直接拖入文件继续导入。'
            : '支持 .json 和 .png，直接复用导入中心逻辑。';
        }
        return;
      }

      selectedWorldbookIndex = focusIndex >= 0 ? focusIndex : visible[0].index;
