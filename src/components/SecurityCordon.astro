---
interface Props {
  unlockClicks?: number;
  label?: string;
}

const { unlockClicks = 10, label = '🔒 模块封锁中 · 开发未完成' } = Astro.props;
---

<div
  class="security-cordon-wrapper locked"
  data-unlock={unlockClicks}
  data-label={label}
>
  <div class="cordon-content-layer">
    <slot />
  </div>

  <button type="button" class="cordon-overlay" aria-label="解锁受限模块">
    <div class="cordon-overlay-inner">
      <span class="cordon-chip">LOCKED</span>
      <div class="cordon-lock-icon">🔐</div>
      <div class="cordon-label-text">{label}</div>
      <div class="cordon-badge-sub">点击 {unlockClicks} 次解锁</div>
      <div class="cordon-progress" aria-hidden="true">
        <span class="cordon-progress-fill"></span>
      </div>
      <div class="cordon-progress-text" data-progress>0 / {unlockClicks}</div>
    </div>
  </button>
</div>

<style is:global>
  .security-cordon-wrapper {
    position: relative;
    isolation: isolate;
    border-radius: 14px;
  }

  .security-cordon-wrapper.locked .cordon-content-layer {
    filter: blur(3px) brightness(0.55) saturate(0.5);
    pointer-events: none;
    user-select: none;
  }

  .security-cordon-wrapper.unlocked .cordon-content-layer {
    filter: none;
    pointer-events: auto;
    user-select: auto;
  }

  .cordon-overlay {
    position: absolute;
    inset: 0;
    z-index: 50;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: inherit;
    background: rgba(2, 6, 23, 0.76);
    color: inherit;
    cursor: pointer;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .cordon-overlay:focus-visible {
    outline: 2px solid rgba(56, 189, 248, 0.45);
    outline-offset: 2px;
  }

  .cordon-overlay-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    max-width: 320px;
  }

  .cordon-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid rgba(248, 113, 113, 0.28);
    background: rgba(248, 113, 113, 0.08);
    color: #fca5a5;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .cordon-lock-icon {
    font-size: 1.9rem;
    line-height: 1;
  }

  .cordon-label-text {
    font-size: 0.86rem;
    font-weight: 700;
    color: #e2e8f0;
    line-height: 1.45;
  }

  .cordon-badge-sub {
    font-size: 0.66rem;
    color: #94a3b8;
  }

  .cordon-progress {
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: rgba(51, 65, 85, 0.8);
    overflow: hidden;
    border: 1px solid rgba(71, 85, 105, 0.4);
  }

  .cordon-progress-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #38bdf8, #8b5cf6);
  }

  .cordon-progress-text {
    font-size: 0.68rem;
    color: #cbd5e1;
    font-family: 'JetBrains Mono', monospace;
  }

  .security-cordon-wrapper.unlocked .cordon-overlay {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script is:inline>
(function () {
  document.querySelectorAll('.security-cordon-wrapper').forEach(function (wrapper) {
    var unlockThreshold = parseInt(wrapper.dataset.unlock, 10) || 10;
    var overlay = wrapper.querySelector('.cordon-overlay');
    var progressText = wrapper.querySelector('[data-progress]');
    var progressFill = wrapper.querySelector('.cordon-progress-fill');
    var count = 0;
    var unlocked = false;

    function syncProgress() {
      var pct = unlockThreshold > 0 ? Math.min((count / unlockThreshold) * 100, 100) : 100;
      if (progressText) progressText.textContent = count + ' / ' + unlockThreshold;
      if (progressFill) progressFill.style.width = pct + '%';

      if (count >= unlockThreshold && !unlocked) {
        unlocked = true;
        wrapper.classList.remove('locked');
        wrapper.classList.add('unlocked');
        if (overlay) overlay.hidden = true;
      }
    }

    if (overlay) {
      overlay.addEventListener('click', function () {
        if (unlocked) return;
        count += 1;
        syncProgress();
      });
    }

    syncProgress();
  });
})();
</script>
