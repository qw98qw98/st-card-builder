---
---
<div class="statusbar-inline-panel">
  <div class="statusbar-head">
    <div>
      <h3>状态栏定义</h3>
      <p class="statusbar-desc">对应导入卡片里的 <code>statusBlockConfig</code> 和 <code>presetStatusBlock</code>，只保留设定和首条状态。</p>
    </div>
  </div>

  <div class="form-group">
    <label>设定 (statusBlockConfig.description)</label>
    <textarea id="sbDescription" class="statusbar-description" placeholder="填写状态栏的模板描述..."></textarea>
  </div>

  <div class="form-group">
    <label>第一个状态 (presetStatusBlock)</label>
    <textarea id="sbPresetStatusBlock" class="statusbar-state-preview" placeholder="填写首条状态块内容..."></textarea>
  </div>
</div>

<style is:global>
  .statusbar-inline-panel {
    margin-top: 10px;
    padding-top: 14px;
    border-top: 1px solid rgba(99, 102, 241, 0.18);
  }

  .statusbar-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .statusbar-head h3 {
    margin: 0;
    font-size: 0.95rem;
    color: #e2e8f0;
  }

  .statusbar-desc {
    margin: 4px 0 0;
    font-size: 0.82rem;
    line-height: 1.6;
    color: #94a3b8;
    max-width: 90ch;
  }

  .statusbar-title {
    width: min(340px, 100%);
  }

  .statusbar-description,
  .statusbar-state-preview {
    min-height: 160px;
    resize: vertical;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    line-height: 1.65;
  }

</style>

<script is:inline>
(function () {
  const sbDescription = document.getElementById('sbDescription');
  const sbPresetStatusBlock = document.getElementById('sbPresetStatusBlock');

  function updateStatePreview() {
    if (!sbPresetStatusBlock) return;
    sbPresetStatusBlock.value = String(sbPresetStatusBlock.value || '');
  }

  function loadState(data) {
    if (!data) {
      sbDescription.value = '📅 寒假第{X}天 · 📍 {地点}\n\n🧩 角色状态设定：';
      sbPresetStatusBlock.value = '📅 寒假第1天 · 📍 酒店1207房间\n\n填写首条状态块内容';
      updateStatePreview();
      return;
    }
    if (data.description !== undefined) sbDescription.value = data.description;
    if (data.presetStatusBlock !== undefined) sbPresetStatusBlock.value = data.presetStatusBlock;
    if (data.title !== undefined && data.presetStatusBlock === undefined) sbPresetStatusBlock.value = data.title;
    updateStatePreview();
  }

  sbDescription.addEventListener('input', updateStatePreview);

  window.__getStatusBarData__ = function() {
    return {
      description: sbDescription.value,
      presetStatusBlock: sbPresetStatusBlock.value,
    };
  };

  window.__loadStatusBarData__ = loadState;
  renderFieldList();
  updateStatePreview();
})();
</script>
