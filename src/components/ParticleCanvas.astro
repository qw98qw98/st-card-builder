<!-- ★ 全屏粒子背景 — 支持特效开关 -->
<canvas id="particleCanvas"></canvas>

<style is:global>
  #particleCanvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }
  .app-header, .app-container {
    position: relative;
    z-index: 1;
  }
</style>

<script>
  import { initParticleCanvas } from '../scripts/particle-canvas';
  initParticleCanvas();
</script>
