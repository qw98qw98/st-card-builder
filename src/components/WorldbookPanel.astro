---
---
<div class="panel area-worldbook wb-panel">
  <div class="wb-head">
    <div>
      <h2>📖 世界书</h2>
      <p class="wb-head-desc">编辑模式用于快速修改，预览模式用于上方看详情、下方看全量词条索引。AI 生成、手动编辑、导入条目分开看，长设定可直接阅读和复制。</p>
    </div>
    <div class="wb-head-meta">
      <span id="wbTotalCount" class="wb-pill">0 条</span>
      <span id="wbAiCount" class="wb-pill wb-pill-ai">AI 0</span>
      <span id="wbManualCount" class="wb-pill wb-pill-manual">手动 0</span>
      <span id="wbImportCount" class="wb-pill wb-pill-import">导入 0</span>
    </div>
  </div>

  <div class="wb-mode-switch">
    <div class="wb-mode-tabs" role="tablist" aria-label="世界书模式">
      <button class="wb-mode-tab is-active" type="button" role="tab" aria-selected="true" data-wb-mode="edit">编辑模式</button>
      <button class="wb-mode-tab" type="button" role="tab" aria-selected="false" data-wb-mode="preview">预览模式</button>
    </div>
    <p class="wb-mode-tip">编辑模式只保留常用编辑项，预览模式改成左侧浏览、右侧完整阅读，支持键盘上下切换与复制。</p>
    <div class="wb-mode-actions">
      <button id="btnExportWorldbookMd" class="btn wb-export-btn" type="button">导出世界书 MD</button>
    </div>
  </div>

  <div class="wb-shell">
    <aside class="wb-column wb-browser">
      <div class="wb-card wb-quick-card">
        <div class="wb-card-head">
          <div>
            <h3>单条补充</h3>
            <p class="wb-card-desc">基于当前角色与已有条目补一条，适合局部扩展。</p>
          </div>
          <span class="wb-pill wb-pill-ai">AI</span>
        </div>

        <div class="wb-quick-form">
          <div class="wb-input-row">
            <input type="text" id="wbSinglePrompt" placeholder="定向要求(可选)，如：写一把专属武器..." />
            <button id="btnAiSingleWb" class="btn btn-ai" style="width:auto; white-space:nowrap;">🎲 生成 1 条</button>
          </div>

          <label class="wb-check">
            <input type="checkbox" id="wbIncludeCharData" checked />
            <span>融合角色信息</span>
          </label>
        </div>
      </div>

      <div class="wb-card wb-list-card">
        <div class="wb-card-head">
          <div>
            <h3>条目浏览</h3>
            <p class="wb-card-desc">先筛选，再点条目进入编辑。</p>
          </div>
        </div>

        <div class="wb-filter-bar" role="tablist" aria-label="世界书筛选">
          <button class="wb-filter-pill is-active" type="button" data-wb-filter="all">全部 <span data-filter-count="all">0</span></button>
          <button class="wb-filter-pill" type="button" data-wb-filter="ai">AI 生成 <span data-filter-count="ai">0</span></button>
          <button class="wb-filter-pill" type="button" data-wb-filter="manual">手动 <span data-filter-count="manual">0</span></button>
          <button class="wb-filter-pill" type="button" data-wb-filter="import">导入 <span data-filter-count="import">0</span></button>
        </div>

        <div id="entriesList" class="wb-entry-list"></div>
      </div>
    </aside>

    <section class="wb-column wb-stage">
      <div class="wb-mode-panel wb-mode-edit" data-wb-mode-panel="edit">
        <div class="wb-card wb-editor-card">
          <div class="wb-card-head">
            <div>
              <h3>条目编辑</h3>
              <p id="wbEditorHint" class="wb-card-desc">点击左侧条目后在这里修改，默认只展示常用字段，高级参数收在折叠区。</p>
            </div>
            <span id="wbEditorSource" class="wb-pill wb-pill-neutral">新建</span>
          </div>

          <div id="wbManualEditArea" class="wb-form-grid">
            <div class="form-group">
              <label>条目标题</label>
              <input type="text" id="entryComment" placeholder="例如：===特殊武器===" />
            </div>

            <div class="form-group">
              <label>设定内容</label>
              <textarea id="entryContent" placeholder="具体设定详情..."></textarea>
            </div>

            <div class="form-group">
              <label>触发词 — 多个用英文逗号隔开</label>
              <input type="text" id="entryKeys" placeholder="空为常驻，有词为触发" />
            </div>

            <details class="wb-advanced-settings">
              <summary>高级设置</summary>
              <div class="wb-advanced-grid">
                <div class="grid-2">
                  <div class="form-group">
                    <label>触发策略</label>
                    <select id="entryStrategy">
                      <option value="constant">常驻</option>
                      <option value="selective" selected>关键词</option>
                      <option value="vectorized">向量化</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label>插入位置</label>
                    <select id="entryPosition">
                      <option value="0">0 — 之前</option>
                      <option value="1">1 — 之后</option>
                      <option value="2">2 — 前 EM</option>
                      <option value="3">3 — 后 EM</option>
                      <option value="4" selected>4 — 深度</option>
                      <option value="5">5 — 之前 AN</option>
                      <option value="6">6 — 之后 AN</option>
                    </select>
                  </div>
                </div>

                <div class="grid-3">
                  <div class="form-group">
                    <label>深度</label>
                    <input type="number" id="entryDepth" value="4" min="0" />
                  </div>
                  <div class="form-group">
                    <label>角色</label>
                    <select id="entryRole">
                      <option value="0">系统</option>
                      <option value="1">用户</option>
                      <option value="2">助手</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label>顺序</label>
                    <input type="number" id="entryOrder" value="100" />
                  </div>
                </div>

                <div class="form-group">
                  <label>概率 (%)</label>
                  <input type="number" id="entryProb" value="100" min="1" max="100" />
                </div>
              </div>
            </details>

            <div class="wb-form-actions">
              <button id="btnAddEntry" class="btn btn-add">➕ 保存到列表</button>
            </div>
          </div>
        </div>

        <div class="wb-card wb-organize-card">
          <div class="wb-card-head">
            <div>
              <h3>AI 智能整理</h3>
              <p class="wb-card-desc">只校准 depth / order / probability，不占主区。</p>
            </div>
            <button id="btnAiOrganize" class="btn btn-organize-magic" type="button">⚡ 一键整理</button>
          </div>
          <div id="organizeStatus" class="wb-status"></div>
          <div id="organizePreview" class="organize-preview-container" style="display:none;"></div>
        </div>
      </div>

      <div class="wb-mode-panel wb-mode-preview" data-wb-mode-panel="preview" hidden>
        <div class="wb-preview-layout">
          <aside class="wb-preview-pane wb-preview-list-pane">
            <div class="wb-card-head wb-preview-head">
              <div>
                <h3>条目浏览</h3>
                <p class="wb-card-desc">上下键、Home/End、首字输入都能切换。左侧列表可快速扫读，右侧专注完整内容。</p>
              </div>
              <span id="wbPreviewListCount" class="wb-pill">0 条</span>
            </div>

            <div class="wb-preview-filter-bar" role="tablist" aria-label="世界书筛选">
              <button class="wb-filter-pill is-active" type="button" data-wb-filter="all">全部 <span data-filter-count="all">0</span></button>
              <button class="wb-filter-pill" type="button" data-wb-filter="ai">AI 生成 <span data-filter-count="ai">0</span></button>
              <button class="wb-filter-pill" type="button" data-wb-filter="manual">手动 <span data-filter-count="manual">0</span></button>
              <button class="wb-filter-pill" type="button" data-wb-filter="import">导入 <span data-filter-count="import">0</span></button>
            </div>

            <div class="wb-preview-empty" id="wbPreviewEmpty">还没有可预览条目。</div>
            <div class="wb-preview-view" id="wbPreviewView" hidden role="listbox" tabindex="0" aria-label="世界书条目列表"></div>
          </aside>

          <section class="wb-preview-pane wb-preview-reader-pane">
            <div class="wb-card-head wb-preview-head">
              <div>
                <h3>完整阅读</h3>
                <p id="wbPreviewSummary" class="wb-card-desc">选择任意条目后，这里会展示完整标题、关键词和设定内容。</p>
                <p id="wbPreviewNotice" class="wb-preview-notice">键盘：↑↓ 切换，Home/End 跳转，输入首字快速定位。</p>
              </div>
              <div class="wb-preview-copy-group">
                <button id="btnCopyPreviewTitle" class="btn wb-copy-btn" type="button">复制标题</button>
                <button id="btnCopyPreviewKeys" class="btn wb-copy-btn" type="button">复制触发词</button>
                <button id="btnCopyPreviewContent" class="btn wb-copy-btn" type="button">复制设定</button>
                <button id="btnCopyPreviewAll" class="btn wb-copy-btn" type="button">复制整条</button>
              </div>
            </div>

            <div class="wb-preview-meta-row">
              <span id="wbPreviewSource" class="wb-pill wb-pill-neutral">来源</span>
              <span id="wbPreviewStrategy" class="wb-chip">策略</span>
              <span id="wbPreviewPosition" class="wb-chip">位置</span>
              <span id="wbPreviewDepth" class="wb-chip">深度</span>
              <span id="wbPreviewOrder" class="wb-chip">顺序</span>
              <span id="wbPreviewProb" class="wb-chip">概率</span>
            </div>

            <div class="wb-preview-detail-grid">
              <section class="wb-preview-block">
                <div class="wb-preview-block-head">
                  <label>标题</label>
                </div>
                <div id="wbPreviewTitle" class="wb-preview-title"></div>
              </section>

              <section class="wb-preview-block">
                <div class="wb-preview-block-head">
                  <label>触发词</label>
                </div>
                <div id="wbPreviewKeys" class="wb-preview-keys"></div>
              </section>

              <section class="wb-preview-block wb-preview-content-block">
                <div class="wb-preview-block-head">
                  <label>设定内容</label>
                </div>
                <pre id="wbPreviewContent" class="wb-preview-content"></pre>
              </section>
            </div>
          </section>
        </div>
      </div>
    </section>
  </div>
</div>

<style is:global>
  .wb-panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .wb-head {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .wb-head-desc {
    margin: 6px 0 0;
    font-size: 0.76rem;
    color: var(--muted);
    max-width: 64ch;
    line-height: 1.5;
  }

  .wb-head-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .wb-mode-switch {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .wb-mode-tabs {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .wb-mode-tab {
    appearance: none;
    border-radius: 999px;
    padding: 8px 14px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
  }

  .wb-mode-tab.is-active {
    background: var(--accent);
    color: #fff;
    border-color: transparent;
  }

  .wb-mode-tip {
    margin: 0;
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .wb-mode-actions {
    display: flex;
    justify-content: flex-start;
  }

  .wb-export-btn {
    width: auto !important;
    padding: 8px 14px !important;
    border-radius: 999px !important;
    background: var(--surface-2) !important;
    border: 1px solid var(--border) !important;
    color: var(--text) !important;
    font-size: 0.76rem !important;
    font-weight: 700 !important;
  }

  .wb-export-btn:hover {
    background: var(--surface-3) !important;
    border-color: var(--border-strong) !important;
  }

  .wb-shell {
    display: grid;
    grid-template-columns: minmax(300px, 0.84fr) minmax(460px, 1.16fr);
    gap: 16px;
    align-items: start;
  }

  .wb-shell.is-preview-mode {
    grid-template-columns: 1fr;
  }

  .wb-shell.is-preview-mode .wb-browser {
    display: none;
  }

  .wb-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .wb-stage {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .wb-mode-panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 0;
  }

  .wb-card {
    background: var(--surface-strong);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 16px;
  }

  .wb-card-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .wb-card-head h3 {
    margin: 0;
    font-size: 0.96rem;
    color: var(--text);
  }

  .wb-card-desc {
    margin: 4px 0 0;
    font-size: 0.72rem;
    color: var(--muted);
    line-height: 1.45;
  }

  .wb-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    font-size: 0.72rem;
    font-weight: 700;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text);
    white-space: nowrap;
  }

  .wb-pill-ai {
    color: var(--accent);
  }

  .wb-pill-manual {
    color: var(--accent-2);
  }

  .wb-pill-import {
    color: var(--muted);
  }

  .wb-pill-neutral {
    color: var(--muted);
  }

  .wb-quick-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wb-input-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    align-items: center;
  }

  .wb-check {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.76rem;
    color: var(--muted);
  }

  .wb-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .wb-filter-pill {
    appearance: none;
    border-radius: 999px;
    padding: 7px 12px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .wb-filter-pill span {
    font-variant-numeric: tabular-nums;
    color: var(--muted);
  }

  .wb-entry-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .wb-entry-empty {
    padding: 16px;
    border-radius: 14px;
    border: 1px dashed var(--border);
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.5;
    background: var(--surface-2);
  }

  .wb-entry {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }

  .wb-entry.is-selected {
    border-color: var(--border-strong);
    background: var(--surface-3);
  }

  .wb-entry-body {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .wb-entry-top {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    align-items: flex-start;
  }

  .wb-entry-top-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: flex-end;
    align-items: center;
  }

  .wb-entry-title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
  }

  .wb-entry-meta {
    margin-top: 4px;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .wb-entry-preview {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .wb-entry-keys {
    font-size: 0.7rem;
    color: var(--muted);
  }

  .wb-entry-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .wb-btn-edit,
  .wb-btn-reroll,
  .wb-btn-delete,
  .wb-btn-reroll-submit {
    width: auto !important;
    padding: 6px 10px !important;
    font-size: 0.74rem !important;
    border-radius: 999px !important;
  }

  .wb-btn-edit {
    background: var(--surface-2) !important;
    color: var(--text) !important;
    border: 1px solid var(--border) !important;
  }

  .wb-btn-reroll,
  .wb-btn-reroll-submit {
    background: var(--accent) !important;
    color: #fff !important;
    border: none !important;
  }

  .wb-btn-delete {
    background: var(--surface-2) !important;
    color: var(--danger) !important;
    border: 1px solid var(--border) !important;
  }

  .wb-reroll-area {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .wb-reroll-area input {
    width: 100%;
  }

  .wb-chip,
  .wb-source-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--muted);
  }

  .wb-source-ai {
    color: var(--accent);
    background: rgba(67, 97, 238, 0.08);
  }

  .wb-source-manual {
    color: var(--accent-2);
    background: rgba(15, 118, 110, 0.08);
  }

  .wb-source-import {
    color: var(--muted);
    background: rgba(148, 163, 184, 0.08);
  }

  .wb-source-skeleton {
    color: var(--warning);
    background: rgba(180, 83, 9, 0.08);
  }

  .wb-form-grid {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .wb-advanced-settings {
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--surface-2);
    padding: 12px 14px;
  }

  .wb-advanced-settings summary {
    cursor: pointer;
    list-style: none;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--text);
  }

  .wb-advanced-settings summary::-webkit-details-marker {
    display: none;
  }

  .wb-advanced-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 12px;
  }

  .wb-form-actions {
    margin-top: 2px;
  }

  .wb-organize-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wb-preview-layout {
    display: grid;
    grid-template-columns: minmax(320px, 0.42fr) minmax(0, 1fr);
    gap: 16px;
    align-items: stretch;
    min-height: 0;
  }

  .wb-preview-head {
    align-items: flex-start;
  }

  .wb-preview-pane {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
    min-height: 0;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--surface-strong);
    padding: 16px;
  }

  .wb-preview-copy-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    justify-content: flex-end;
  }

  .wb-copy-btn {
    width: auto !important;
    padding: 7px 12px !important;
    font-size: 0.74rem !important;
    border-radius: 999px !important;
    border: 1px solid var(--border) !important;
    background: var(--surface-2) !important;
    color: var(--text) !important;
  }

  .wb-copy-btn:hover {
    background: var(--surface-3) !important;
    border-color: var(--border-strong) !important;
  }

  .wb-preview-detail-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .wb-preview-list-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 0;
  }

  .wb-status {
    min-height: 20px;
    font-size: 0.76rem;
    color: var(--muted);
    line-height: 1.4;
  }

  .wb-organize-card .btn-organize-magic {
    width: auto;
    padding: 8px 14px;
    white-space: nowrap;
  }

  .organize-preview-container {
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    overflow: hidden;
  }

  .organize-preview-header {
    background: var(--surface);
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .preview-header-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

