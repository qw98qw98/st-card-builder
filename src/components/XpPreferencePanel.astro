---
const src = "/xp-preference-set-20260315.html";
---

<div class="xp-shell">
  <div class="xp-head">
    <div>
      <h2 class="xp-title">XP 偏好设定集</h2>
    </div>
  </div>

  <iframe
    class="xp-frame"
    src={src}
    title="XP 偏好设定集 20260315"
    loading="eager"></iframe>
</div>

<style>
  .xp-shell {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .xp-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 0 2px;
  }

  .xp-title {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    color: #e2e8f0;
  }

  .xp-desc {
    margin: 4px 0 0;
    font-size: 0.72rem;
    line-height: 1.4;
    color: #64748b;
  }

  .xp-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid rgba(99, 102, 241, 0.28);
    background: rgba(99, 102, 241, 0.12);
    color: #c7d2fe;
    font-size: 0.68rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .xp-frame {
    width: 100%;
    min-height: calc(100svh - 240px);
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 16px;
    background: #ffffff;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .xp-head {
      align-items: flex-start;
      flex-direction: column;
    }

    .xp-frame {
      min-height: calc(100svh - 220px);
    }
  }
</style>
